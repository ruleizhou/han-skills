{
  "_schema": "patterns.json — llm-wiki 配图经验库。每次配图后将验证有效的「内容类型→引擎/图表类型组合」沉淀于此,ingest/save 配图判断时(读)给推荐、配图完成后(写)沉淀。确定性引擎(D2/han-svg)本就稳定,confidence 累积更慢;AI 引擎随 key/风格波动,confidence 更敏感。",
  "_confidence_rules": {
    "on_success": "frequency += 1; 命中已有条目则 last_seen 更新(不自动 +confidence,避免自吹捧,留给用户反馈); 新组合追加 confidence=1",
    "on_degradation": "原 AI 条目 confidence -= 1, outcome=degraded; 降级用的确定性兜底条目 frequency += 1",
    "on_failure": "confidence -= 1, outcome=failed",
    "on_confidence_below_zero": "从 patterns 数组中移除该条目",
    "high_confidence_threshold": "confidence >= 3 在配图判断时作为强推荐命中"
  },
  "_fields": {
    "id": "唯一标识 wptrn-NNN",
    "name": "组合简述",
    "category": "固定为 content-engine-recommend",
    "content_type": "内容类型,如 技术架构/处理流程/对比选型/时间线/高密度总览/暖色总结/物体拆解",
    "engine": "d2 | han-svg | han-infographic | han-hand-write-pic | han-disassembly-diagram",
    "diagram_type": "引擎内图表类型: D2→system-architecture/flowchart/state-machine/sequence-diagram/er-diagram/class-diagram/network-topology/gantt-chart; han-svg→matrix/timeline/architecture/flowchart; AI→对应 layout/mode",
    "style": "风格,仅 AI 引擎有意义: technical-map/lab-notes/journal/hand-drawn-edu/chubby-sketch/hybrid/exploded/cutaway 等;D2/han-svg 为 null",
    "aspect": "推荐画幅 landscape/portrait/square",
    "engine_note": "可选补充: D2 布局引擎 elk/dagre;han-svg 主题 dark-tech/han-light",
    "description": "为什么这个组合适合该内容类型",
    "confidence": "置信度,初始 1",
    "frequency": "使用次数",
    "keywords": "内容类型关键词,配图判断时匹配",
    "first_seen": "首次发现 YYYY-MM-DD",
    "last_seen": "最近一次 YYYY-MM-DD",
    "outcome": "success / degraded / failed"
  },
