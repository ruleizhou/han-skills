{
  "_schema": "patterns.json — 信息图参数经验库。每次出图后将验证有效的「内容类型→布局/风格组合」沉淀于此,Step 1 用它给参数推荐。",
  "_confidence_rules": {
    "on_success": "confidence += 1, frequency += 1",
    "on_failure": "confidence -= 1",
