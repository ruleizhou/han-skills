    "style": "推荐的 style 值",
    "aspect": "推荐画幅 landscape/portrait/square",
    "description": "为什么这个组合适合该内容类型",
    "confidence": "置信度,初始 1,success +1 / fail -1",
    "frequency": "使用次数",
    "keywords": "内容类型关键词,用于 Step 1 匹配",
    "first_seen": "首次发现 YYYY-MM-DD",
